#!/usr/bin/env bash

# 1: qps, 2: query_distribution, 3: coefficient_variation
# 4: dataset_type, 5: dataset_path
# 6: dispatch_strategy, 7: enable_migrate, 8: enable_defrag, 9: migrate_threshold
# 10: log_dirname
# Optional env: HEAD_NODE_IP, MODEL_PATH, DATASET_PATH (override $5), IP_PORTS

# 2-node config (1 GPU per node): head at 8000, benchmark connects to head
export HEAD_NODE_IP="${HEAD_NODE_IP:-172.31.9.153}"
export PORT="${PORT:-8000}"
export IP_PORTS="${IP_PORTS:-${HEAD_NODE_IP}:${PORT}}"
export MODEL_PATH="${MODEL_PATH:-/mnt/data/huggingface_cache/hub/models--meta-llama--Llama-3.2-1B-Instruct/snapshots/9213176726f574b556790deb65791e0c5aa438b6}"
# Dataset path can be overridden by env; else use positional $5
if [ -n "${DATASET_PATH}" ]; then
  dataset_path_override="${DATASET_PATH}"
fi

instance_parallel_size=2
max_batch_total_tokens_vals=("4096")
# PORT already set above

num_prompts=200
qps=$1
# burst, uniform, poisson, gamma
query_distribution=$2
coefficient_variation=$3

# idist: uniform, exponential, capped_exponential, zipf
idist=zipf
imean=128
irange=6144
# odist: uniform, exponential, capped_exponential, zipf
odist=zipf
omean=128
orange=6144
dataset_type=$4
dataset_path="${dataset_path_override:-$5}"

# dispatch_strategy: balanced, load
dispatch_strategy=$6
enable_migrate=$7
enable_defrag=$8
need_migrate_frequency=4
migrate_threshold=$9

log_dirname=${10}

log_path="qps${qps}_prompts${num_prompts}_${query_distribution}_cv${coefficient_variation}_imean${imean}_omean${omean}_${dispatch_strategy}_migrate${enable_migrate}_defrag${enable_defrag}"
if [ -n $log_dirname ]; then
    log_path=$log_dirname"/"$log_path
fi

shell params: 
./config/serving_exp_dataset 3.5 poisson 1.0 sharegpt ./sharegpt_gpt4.jsonl load 1 1 3 sharegpt/Llumnix-all 